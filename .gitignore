secrets/

# Claude Code settings (contains personal paths & server IPs)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.gstack/

# Release artifacts (built on demand)
releases/
.nightcrawl/
tmp/visual/

# Claude workflow state (hook-enforced, not part of codebase)
.claude/workflow.md
.claude/tasks/

# Codex harness — runtime, tasks, agents, hooks, config, workspace.
# Process/scratch files, not product. Already-tracked specs stay tracked.
.codex/

# Build / release artifacts (regenerable)
dist/
*.zip
*.dmg
*.sha256
tmp/
__pycache__/

# Codex runtime state
.codex/runtime/
