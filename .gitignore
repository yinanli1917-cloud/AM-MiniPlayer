# Codex harness — personal AI-agent tooling, projected from the global
# ~/.codex/harness (regenerable via codex_harness.py migrate). Kept OUT of this
# public product repo: not part of nanoPod, and its probe dumps had captured
# machine-local personal state. Continuity lives in the private global harness.
.codex/

# Build / release artifacts (regenerable)
dist/
*.zip
*.dmg
*.sha256
tmp/
__pycache__/

# Kymograph visual-regression baseline recordings (machine-local, large binaries;
# recovered from the pre-migration machine — see .kymo-baseline/README.md)
.kymo-baseline/
